// commands/block.js
const isOwnerOrSudo = require('../lib/isOwner');

async function blockCommand(sock, chatId, message) {
    try {
        // Check if sender is owner/sudo
        const senderId = message.key.participant || message.key.remoteJid;
        const senderIsOwner = await isOwnerOrSudo(senderId, sock, chatId);
        
        if (!message.key.fromMe && !senderIsOwner) {
            return await sock.sendMessage(chatId, { 
                text: '❌ This command is only for the owner/sudo.' 
            }, { quoted: message });
        }

        const mentioned = message.message.extendedTextMessage?.contextInfo?.mentionedJid || [];
        let targetJid = mentioned[0];

        if (!targetJid && message.key.remoteJid.endsWith('@s.whatsapp.net')) {
            targetJid = message.key.remoteJid;
        }

        if (!targetJid) {
            return await sock.sendMessage(chatId, { 
                text: '❌ Please mention a user or use this command in their DM.\nExample: .block @user' 
            });
        }

        await sock.updateBlockStatus(targetJid, 'block');
        
        await sock.sendMessage(chatId, { 
            text: `✪ \`\`\`User Blocked\`\`\`\n\n@${targetJid.split('@')[0]} has been blocked.`,
            mentions: [targetJid]
        }, { quoted: message });
    } catch (error) {
        console.error('Error in block command:', error);
        await sock.sendMessage(chatId, { text: '❌ Failed to block user.' });
    }
}

module.exports = blockCommand;